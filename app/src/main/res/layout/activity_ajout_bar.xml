<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <EditText
            android:id="@+id/nom_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Nom du Spot"
            android:minHeight="48dp"
            android:textColor="@color/dark_brown"
            android:textColorHint="@color/light_brown" />

        <EditText
            android:id="@+id/adresse_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Adresse du Spot"
            android:minHeight="48dp"
            android:textColor="@color/dark_brown"
            android:textColorHint="@color/light_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Note :"
            android:textColor="@color/dark_brown"
            android:textStyle="bold" />

        <RatingBar
            android:id="@+id/rating_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:numStars="5"
            android:progressTint="@color/dark_brown"
            android:stepSize="1" />

        <EditText
            android:id="@+id/comm_bar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:hint="Petit commentaire..."
            android:minHeight="48dp"
            android:textColor="@color/dark_brown"
            android:textColorHint="@color/light_brown" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="Ambiances (max 3) :"
            android:textColor="@color/dark_brown"
            android:textStyle="bold" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chip_group_ambiance"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            app:chipSpacingHorizontal="8dp"
            app:chipSpacingVertical="8dp">

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_chill"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Chill"
                android:textColor="@color/light_blue"
                app:chipBackgroundColor="@color/blue" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_techno"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Culturel"
                android:textColor="@color/light_blue"
                app:chipBackgroundColor="@color/blue" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_rock"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Espace vert"
                android:textColor="@color/light_blue"
                app:chipBackgroundColor="@color/blue" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_cocktails"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Éducatif"
                android:textColor="@color/light_blue"
                app:chipBackgroundColor="@color/blue" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chip_electro"
                style="@style/Widget.MaterialComponents.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="New gen"
                android:textColor="@color/light_blue"
                app:chipBackgroundColor="@color/blue" />

        </com.google.android.material.chip.ChipGroup>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Aperçu de la position :"
            android:textColor="@color/light_brown"
            android:textStyle="bold" />

        <org.osmdroid.views.MapView
            android:id="@+id/map_preview"
            android:layout_width="match_parent"
            android:layout_height="214dp"
            android:layout_marginTop="10dp" />

        <Button
            android:id="@+id/btn_add_photo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:backgroundTint="#555555"
            android:text="Ajouter une photo" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="8dp"
            android:background="#33FFFFFF"
            android:orientation="horizontal"
            android:padding="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Rendre ce spot privé (caché aux amis)"
                android:textColor="@color/light_brown"
                android:textSize="14sp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_private"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:thumbTint="@color/dark_brown" />
        </LinearLayout>

        <Button
            android:id="@+id/save_bar_btn"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="8dp"
            android:backgroundTint="@color/dark_brown"
            android:text="ENREGISTRER LE SPOT"
            android:textStyle="bold" />

    </LinearLayout>
</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <TextView
        android:id="@+id/title_inscription"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="68dp"
        android:fontFamily="@font/quicksand_bold"
        android:text="Inscription"
        android:textColor="@color/dark_brown"
        android:textSize="34sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/inscription_email"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="74dp"
        android:layout_marginBottom="8dp"
        android:ems="12"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Email"
        android:inputType="textEmailAddress"
        android:textColor="@color/light_grey"
        android:textColorHint="@color/light_grey"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/inscription_pseudo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/title_inscription" />

    <EditText
        android:id="@+id/inscription_pseudo"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:ems="12"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Pseudo"
        android:inputType="textPersonName"
        android:textColor="@color/light_grey"
        android:textColorHint="@color/light_grey"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/inscription_password"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inscription_email" />

    <EditText
        android:id="@+id/inscription_dob"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:ems="12"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Date de naissance (JJ/MM/AAAA)"
        android:inputType="date"
        android:textColor="@color/light_grey"
        android:textColorHint="@color/light_grey"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/inscription_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inscription_confirm" />

    <EditText
        android:id="@+id/inscription_password"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:ems="12"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Mot de passe"
        android:inputType="textPassword"
        android:textColor="@color/light_grey"
        android:textColorHint="@color/light_grey"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/inscription_confirm"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inscription_pseudo" />

    <EditText
        android:id="@+id/inscription_confirm"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:ems="12"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Confirmer le mot de passe"
        android:inputType="textPassword"
        android:textColor="@color/light_grey"
        android:textColorHint="@color/light_grey"
        android:textSize="16sp"
        app:layout_constraintBottom_toTopOf="@+id/inscription_dob"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inscription_password" />

    <TextView
        android:id="@+id/inscription_error"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:textColor="@color/pink"
        android:visibility="invisible"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inscription_confirm" />

    <Button
        android:id="@+id/inscription_btn"
        android:layout_width="310dp"
        android:layout_height="44dp"
        android:layout_marginTop="114dp"
        android:layout_marginBottom="4dp"
        android:backgroundTint="@color/dark_brown"
        android:fontFamily="@font/quicksand_bold"
        android:text="S'inscrire"
        android:textAllCaps="false"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toTopOf="@+id/go_login"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inscription_dob" />

    <TextView
        android:id="@+id/go_login"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="@font/quicksand_bold"
        android:text="Déjà un compte ? Se connecter"
        android:textColor="@color/light_brown"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/inscription_btn" />

</androidx.constraintlayout.widget.ConstraintLayout>
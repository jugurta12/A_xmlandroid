<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    android:padding="20dp">

    <ImageView
        android:id="@+id/profil_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="50dp"
        android:background="@color/light_brown"
        android:scaleType="centerCrop"
        android:src="@android:drawable/ic_menu_camera"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/edit_email"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="60dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Modifier Email"
        android:inputType="textEmailAddress"
        android:textColor="@color/dark_brown"
        android:textColorHint="@color/light_brown"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/edit_pseudo"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/profil_image" />

    <EditText
        android:id="@+id/edit_pseudo"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Modifier Pseudo"
        android:textColor="@color/dark_brown"
        android:textColorHint="@color/light_brown"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/edit_dob"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_email" />

    <EditText
        android:id="@+id/edit_dob"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Modifier Date de naissance (JJ/MM/AAAA)"
        android:inputType="date"
        android:textColor="@color/dark_brown"
        android:textColorHint="@color/light_brown"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/edit_old_password"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_pseudo" />

    <EditText
        android:id="@+id/edit_old_password"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Ancien mot de passe"
        android:inputType="textPassword"
        android:textColor="@color/dark_brown"
        android:textColorHint="@color/light_brown"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/edit_new_password"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_dob" />

    <EditText
        android:id="@+id/edit_new_password"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="40dp"
        android:fontFamily="@font/quicksand_medium"
        android:hint="Nouveau mot de passe"
        android:inputType="textPassword"
        android:textColor="@color/dark_brown"
        android:textColorHint="@color/light_brown"
        android:textSize="14sp"
        app:layout_constraintBottom_toTopOf="@+id/save_btn"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_old_password" />

    <Button
        android:id="@+id/save_btn"
        android:layout_width="325dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="100dp"
        android:backgroundTint="@color/dark_brown"
        android:fontFamily="@font/quicksand_bold"
        android:text="Enregistrer les modifications"
        android:textAllCaps="false"
        android:textSize="16sp"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/edit_new_password" />

</androidx.constraintlayout.widget.ConstraintLayout>